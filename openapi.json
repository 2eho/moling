  "components": {
    "schemas": {
      "AdminStatsResp": {
        "properties": {
          "user_count": {
            "type": "integer",
            "title": "User Count",
            "description": "总用户数"
          },
          "project_count": {
            "type": "integer",
            "title": "Project Count",
            "description": "总项目数"
          },
          "chapter_count": {
            "type": "integer",
            "title": "Chapter Count",
            "description": "总章节数"
          },
          "task_count": {
            "type": "integer",
            "title": "Task Count",
            "description": "总任务数"
          }
        },
        "type": "object",
        "required": [
          "user_count",
          "project_count",
          "chapter_count",
          "task_count"
        ],
        "title": "AdminStatsResp",
        "description": "Admin statistics response."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "LLMConfigReq": {
        "properties": {
          "api_key": {
            "type": "string",
            "title": "Api Key",
            "description": "LLM API Key"
          },
          "api_base": {
            "type": "string",
            "title": "Api Base",
            "description": "LLM API Base URL",
            "default": "https://api.deepseek.com"
          },
          "model": {
            "type": "string",
            "title": "Model",
            "description": "Default model",
            "default": "deepseek-chat"
          }
        },
        "type": "object",
        "required": [
          "api_key"
        ],
        "title": "LLMConfigReq",
        "description": "Request body for saving LLM configuration."
      },
      "LLMConfigResp": {
        "properties": {
          "api_base": {
            "type": "string",
            "title": "Api Base",
            "description": "LLM API Base URL"
          },
          "model": {
            "type": "string",
            "title": "Model",
            "description": "Default model"
          },
          "is_configured": {
            "type": "boolean",
            "title": "Is Configured",
            "description": "Whether LLM is configured"
          },
          "api_key_masked": {
            "type": "string",
            "title": "Api Key Masked",
            "description": "Masked API key for display",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "api_base",
          "model",
          "is_configured"
        ],
        "title": "LLMConfigResp",
        "description": "Response for LLM configuration endpoints."
      },
      "UpdateUserReq": {
        "properties": {
          "email": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Email",
            "description": "邮箱"
          },
          "username": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 100,
                "minLength": 1
              },
              {
                "type": "null"
              }
            ],
            "title": "Username",
            "description": "用户名"
          },
          "bio": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Bio",
            "description": "个人简介"
          },
          "role": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Role",
            "description": "角色"
          },
          "status": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Status",
            "description": "状态"
          }
        },
        "type": "object",
        "title": "UpdateUserReq",
        "description": "Admin update user request (all fields optional)."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
