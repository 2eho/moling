/* ========================================
   墨灵 Landing Page Styles
   设计系统 v1.0 - CSS 变量版
   ======================================== */

/* ========================================
   §1 设计令牌 (Design Tokens)
   ======================================== */
:root {
  /* ── 背景层次 ── */
  --color-bg: #0d0f1a;
  --color-surface: #151829;
  --color-elevated: #111327;

  /* ── 文字 ── */
  --color-text-primary: #e8e9f0;
  --color-text-secondary: #9ca3c4;
  --color-text-tertiary: #6b7199;
  --color-text-disabled: #3d4166;

  /* ── 品牌 ── */
  --color-brand-indigo: #6366f1;
  --color-brand-amber: #d4a843;
  --color-brand-indigo-dim: rgba(99, 102, 241, 0.12);
  --color-brand-amber-dim: rgba(212, 168, 67, 0.15);

  /* ── 边框 ── */
  --color-border: #2a2d45;
  --color-border-subtle: #1e2138;

  /* ── 语义 ── */
  --color-success: #34d399;
  --color-warning: #fbbf24;
  --color-danger: #ef4444;

  /* ── 稀有度 ── */
  --rarity-common: #9ca3af;
  --rarity-rare: #67e8f9;
  --rarity-epic: #a855f7;
  --rarity-legendary: #d4a843;

  /* ── 间距 ── */
  --space-1: 4px;
  --space-2: 8px;
  --space-3: 12px;
  --space-4: 16px;
  --space-5: 20px;
  --space-6: 24px;
  --space-8: 32px;
  --space-10: 40px;
  --space-12: 48px;

  /* ── 圆角 ── */
  --radius-sm: 4px;
  --radius-md: 8px;
  --radius-lg: 12px;
  --radius-xl: 16px;
  --radius-2xl: 20px;

  /* ── 阴影 ── */
  --shadow-sm: 0 2px 4px rgba(0,0,0,0.2), 0 1px 2px rgba(99,102,241,0.08);
  --shadow-md: 0 4px 8px rgba(0,0,0,0.25), 0 2px 4px rgba(99,102,241,0.1);
  --shadow-lg: 0 8px 16px rgba(0,0,0,0.3), 0 4px 8px rgba(99,102,241,0.12);

  /* ── 动画 ── */
  --ease-default: cubic-bezier(0.4, 0, 0.2, 1);
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  --duration-fast: 100ms;
  --duration-normal: 200ms;
  --duration-slow: 300ms;
  --duration-slower: 500ms;

  /* ── 布局 ── */
  --header-height: 52px;
  --mobile-bottom-nav-height: 56px;
}

/* ========================================
   §2 共享重置
   ======================================== */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html, body {
  height: 100%;
  font-family: -apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  background: var(--color-bg);
  color: var(--color-text-primary);
  font-size: 14px;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  -webkit-tap-highlight-color: transparent;
}

button {
  cursor: pointer;
  font-family: inherit;
  border: none;
  background: none;
  color: inherit;
}

a {
  color: inherit;
  text-decoration: none;
}

/* 滚动条 */
::-webkit-scrollbar { width: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--color-border); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--color-text-tertiary); }