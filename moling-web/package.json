{
  "name": "moling-web-vite",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "biome check --write ./src ../packages/ui/src",
    "lint:check": "biome check ./src ../packages/ui/src",
    "format": "biome format --write ./src ../packages/ui/src",
    "analyze": "BUILD_ANALYZE=true vite build",
    "tauri:dev": "cargo tauri dev && bash scripts/clean-old-cargo-builds.sh",
    "tauri:build": "cargo tauri build && bash scripts/clean-old-cargo-builds.sh",
    "clean:build": "bash scripts/clean-old-cargo-builds.sh"
  },
  "dependencies": {
    "@moling/ui": "workspace:*",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-toast": "^1.2.17",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tanstack/react-query": "^5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.6.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/cli": "^2.11.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "postcss": "^8.5.15",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.7.0",
    "vite": "^7.2.7"
  }
