graph TD
    subgraph "连载书导入引擎 (app/ingest/)"
        subgraph "API Layer (router.py)"
            POST_url["POST /api/v1/ingest/url"]
            POST_html["POST /api/v1/ingest/html"]
            POST_text["POST /api/v1/ingest/text"]
            GET_toc["GET /api/v1/ingest/toc"]
            POST_crawl["POST /api/v1/ingest/crawl"]
        end

        subgraph "Service Layer (service.py)"
            IngestService
        end

        subgraph "dissector (Phase 0)"
            direction LR
            core["core/\nfetcher.py\ncleaner.py\nextractor.py\ntoc_crawler.py"]
            splitter["splitter/\nchapter.py\nparagraph.py\nstrategies.py"]
            models["models/\nschemas.py"]
            pipeline["pipeline.py"]
            export["export.py"]
        end

        subgraph "Phase 1-3 (待实现)"
            P1["Phase 1: 全量四库分析\n(LLM异步调用)"]
            P2["Phase 2: 近三章动态层分析"]
            P3["Phase 3: 冲突校验 + 事物写入"]
        end
    end

    subgraph "外部依赖"
        HTTP["requests + bs4\n(HTTP采集+HTML解析)"]
        Files["文件系统\n(进度JSON)"]
    end

    subgraph "内部对接"
        DB["PostgreSQL\n(四库表/章节表)"]
        Redis["Redis\n(进度缓存/锁)"]
        Celery["Celery Worker\n(异步分析)"]
    end

    POST_url --> IngestService
    POST_html --> IngestService
    POST_text --> IngestService
    GET_toc --> IngestService
    POST_crawl --> IngestService

    IngestService --> pipeline
    IngestService --> toc_crawler

    pipeline --> core
    pipeline --> splitter
    pipeline --> models
    pipeline --> export

    toc_crawler --> core
    toc_crawler --> pipeline

    core --> HTTP

    IngestService -.-> P1
    P1 --> P2
    P2 --> P3
    P3 --> DB
    P3 --> Redis
    P3 --> Celery

    style POST_url fill:#4a9eff,color:#fff
    style POST_html fill:#4a9eff,color:#fff
    style POST_text fill:#4a9eff,color:#fff
    style GET_toc fill:#4a9eff,color:#fff
    style POST_crawl fill:#4a9eff,color:#fff
    style P1 fill:#888,color:#fff,stroke-dasharray: 5 5
    style P2 fill:#888,color:#fff,stroke-dasharray: 5 5
    style P3 fill:#888,color:#fff,stroke-dasharray: 5 5
