# ==============================================================================
# 墨灵 Moling — 环境变量模板（Rust 后端）
# ==============================================================================
# 复制为 .env 并填写实际值
#   cp docker/.env.example docker/.env
# ==============================================================================

# ── 后端 (Rust Axum) ──────────────────────────────────────────
MOLING_HOST=0.0.0.0
MOLING_PORT=8000
MOLING_DATABASE_URL=sqlite:///data/moling.db?mode=rwc
MOLING_REDIS_URL=redis://:moling_redis_password@redis:6379/0
MOLING_ENVIRONMENT=production
MOLING_DEPLOY_VERSION=latest

# ── 数据库（PostgreSQL） ─────────────────────────────────────
POSTGRES_USER=moling
POSTGRES_PASSWORD=moling
POSTGRES_DB=moling

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=moling_redis_password

# ── Grafana 管理员 ───────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_BASE_URL=http://localhost:3001

# ── 部署配置 ─────────────────────────────────────────────────
DEPLOY_VERSION=latest
GITHUB_REPOSITORY=2eho/moling

# ── 飞书 Webhook（必填） ──────────────────────────────────────
# 在飞书群 → 设置 → 群机器人 → 添加自定义机器人 → 复制 Webhook URL
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 飞书签名校验（可选，推荐） ────────────────────────────────
# 在飞书机器人设置页面 → 安全设置 → 签名校验 → 复制密钥
FEISHU_SECRET=
