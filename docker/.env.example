# ==============================================================================
# Moling — 环境变量模板
# ==============================================================================
# 复制为 .env 并填写实际值
#   cp docker/.env.example docker/.env
# ==============================================================================

# ── 数据库（PostgreSQL） ─────────────────────────────────────
POSTGRES_USER=moling
POSTGRES_PASSWORD=moling
POSTGRES_DB=moling

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=moling_redis_password

# ── 数据持久化路径 ───────────────────────────────────────────
PGDATA_PATH=./data/postgres
REDISDATA_PATH=./data/redis

# ── 应用配置 ─────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///app/data/moling.db
DEPLOY_VERSION=latest
GITHUB_REPOSITORY=2eho/moling

# ── Grafana 管理员 ───────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_BASE_URL=http://localhost:3001

# ── 飞书 Webhook（必填） ──────────────────────────────────────
# 在飞书群 → 设置 → 群机器人 → 添加自定义机器人 → 复制 Webhook URL
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 飞书签名校验（可选，推荐） ────────────────────────────────
# 在飞书机器人设置页面 → 安全设置 → 签名校验 → 复制密钥
FEISHU_SECRET=
