# Moling Backend .dockerignore
# 忽略不需要复制到 Docker 镜像的文件和目录

# Python 虚拟环境
.venv
venv
env

# Python 缓存
__pycache__
*.py[cod]
*$py.class
*.so
.Python

# 测试和覆盖率
tests/
.pytest_cache/
.coverage
htmlcov/
.coverage.*
nosetests.xml
coverage.xml

# 开发环境配置
.env
.env.local
.env.development
.env.production
.env.test

# Git 相关
.git
.gitignore
.gitattributes

# 文档
*.md
LICENSE
README.md
CHANGELOG.md
docs/

# IDE 配置
.vscode/
.idea/
*.swp
*.swo
*~

# 日志文件
logs/
*.log

# 数据库文件
*.db
*.sqlite
*.sqlite3

# Alembic（如果需要重新生成迁移）
# alembic/versions/

# 构建产物
dist/
build/
*.egg-info/
.eggs/

# 系统文件
.DS_Store
Thumbs.db

# CI/CD
.github/
.gitlab-ci.yml
Jenkinsfile
