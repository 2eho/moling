# ==============================================================================
# Moling Backend 环境变量配置模板
# ==============================================================================
# 使用说明:
#   1. 复制此文件为 .env
#   2. 修改以下变量的值为实际配置
#   3. 不要将此文件提交到 Git（已加入 .gitignore）
# ==============================================================================

# ==============================================================================
# 数据库配置
# ==============================================================================
POSTGRES_USER=moling
POSTGRES_PASSWORD=moling_secure_password_change_me
POSTGRES_DB=moling

# ==============================================================================
# Redis 配置
# ==============================================================================
REDIS_PASSWORD=moling_redis_password_change_me

# ==============================================================================
# 应用配置
# ==============================================================================
# 应用环境 (development/staging/production)
APP_ENV=development

# 密钥（生产环境必须使用强随机密钥）
# 生成方法: openssl rand -hex 32
SECRET_KEY=change-me-to-a-secure-random-secret-key

# JWT Token 过期时间
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==============================================================================
# LLM API 配置
# ==============================================================================
# LLM API Key（例如 DeepSeek、OpenAI 等）
LLM_API_KEY=your-llm-api-key-here

# LLM API Base URL
# DeepSeek: https://api.deepseek.com
# OpenAI: https://api.openai.com
# 本地 OAI模型: http://host.docker.internal:4000/v1
LLM_BASE_URL=https://api.deepseek.com

# LLM 模型名称
# DeepSeek: deepseek-chat, deepseek-coder
# OpenAI: gpt-4, gpt-3.5-turbo
LLM_MODEL=deepseek-chat

# ==============================================================================
# Celery 配置（异步任务）
# ==============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ==============================================================================
# 数据库 URL（完整 URL，如果不使用上面的拆分配置）
# ==============================================================================
DATABASE_URL=postgresql+asyncpg://moling:moling_secure_password_change_me@localhost:5432/moling

# ==============================================================================
# Redis URL（完整 URL，如果不使用上面的拆分配置）
# ==============================================================================
REDIS_URL=redis://localhost:6379/0

# ==============================================================================
# 日志配置
# ==============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==============================================================================
# CORS 配置（跨域请求）
# ==============================================================================
# 允许的前端域名（逗号分隔）
ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# ==============================================================================
# 文件上传配置
# ==============================================================================
# 最大上传文件大小（字节）
MAX_UPLOAD_SIZE=10485760

# 上传文件存储路径
UPLOAD_DIR=./uploads

# ==============================================================================
# 生产环境额外配置
# ==============================================================================
# HTTPS 强制跳转（生产环境启用）
# FORCE_HTTPS=true

# 信任的代理 IP（生产环境配置）
# TRUSTED_PROXIES=127.0.0.1,10.0.0.0/8

# ==============================================================================
# 可选：Sentry 错误监控
# ==============================================================================
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/xxx

# ==============================================================================
# 可选：邮件配置（用于发送通知）
# ==============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=no-reply@yourdomain.com
