# =============================================================================
# 墨灵 (Moling) 后端环境变量示例
# =============================================================================
# 复制此文件为 .env 并填写实际值
# 警告：不要将包含真实密钥的 .env 文件提交到版本控制
# =============================================================================

# ---- 环境 ----
ENVIRONMENT=development  # development | staging | production

# ---- 数据库 ----
# SQLite（开发环境）
DATABASE_URL=sqlite+aiosqlite:///./moling.db
# PostgreSQL（生产环境）
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/moling

# Redis
REDIS_URL=redis://localhost:6379/0

# ---- 认证 / JWT ----
# 生产环境必须使用强密钥！生成命令：openssl rand -hex 32
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- LLM 服务 ----
LLM_API_BASE=https://api.deepseek.com
LLM_API_KEY=sk-placeholder  # 生产环境必须通过环境变量设置真实密钥

# ---- Celery ----
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- CORS ----
# 生产环境必须配置具体的允许域名（逗号分隔）
# 例：CORS_ORIGINS=https://moling.example.com,https://www.moling.example.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Sentry 错误监控 ----
# 从 Sentry 后台获取 DSN
# 格式：https://<key>@<organization>.ingest.sentry.io/<project>
# 留空则禁用 Sentry
SENTRY_DSN=

# ---- 速率限制 ----
RATE_LIMIT_CALLS=1000  # 每个周期允许的请求数
RATE_LIMIT_PERIOD=60   # 周期（秒）

# ---- 归档 ----
ARCHIVE_DIR=./archives
