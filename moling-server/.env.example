# =============================================================================
# Moling (墨灵) - 环境变量配置示例
# =============================================================================
# 使用方法：
#   1. 复制本文件为 .env
#   2. 填入真实的值（特别是 REQUIRED 项）
#   3. 切勿将 .env 提交到版本控制
# =============================================================================


# === 运行环境 ===

# 运行环境 (OPTIONAL, default: development)
# 可选值: development | staging | production
# 生产部署必须切换为 production，会启用更严格的安全策略和性能优化
# ENVIRONMENT=development


# === 数据库 ===

# 数据库连接 URL (REQUIRED)
# MVP 默认使用 SQLite（无需额外配置）
#   本地开发: sqlite+aiosqlite:///./moling.db
#   Docker 部署: sqlite+aiosqlite:///app/data/moling.db
# 生产环境可切换为 PostgreSQL:
#   postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
# !!! PostgreSQL 时务必替换为真实强密码 !!!
DATABASE_URL=sqlite+aiosqlite:///./moling.db

# Redis 连接 URL (REQUIRED - 用于 Celery 任务队列)
# 格式: redis://<host>:<port>/<db>
# Docker 部署: docker-compose 中服务名为 redis://redis:6379/0
# 非 Docker 部署（本地开发）: redis://localhost:6379/0
# 若 Redis 不可用，可设置为空字符串（REDIS_URL=），应用会降级运行
REDIS_URL=redis://localhost:6379/0


# === JWT 认证 ===

# JWT 签名密钥 (REQUIRED - 生产环境必须设置为强密钥，务必修改此值)
# 生成强密钥: openssl rand -hex 32
# !!! 切勿在生产环境使用此默认值 !!!
SECRET_KEY=dev-secret-key-change-in-production

# JWT 签名算法 (OPTIONAL, default: HS256)
# ALGORITHM=HS256

# Access Token 过期时间（分钟）(OPTIONAL, default: 15)
# ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh Token 过期时间（天）(OPTIONAL, default: 7)
# REFRESH_TOKEN_EXPIRE_DAYS=7


# === LLM / AI 服务 ===

# LLM API Base URL (OPTIONAL, default: https://api.deepseek.com)
# 支持 OpenAI 兼容格式的 API
# LLM_API_BASE=https://api.deepseek.com

# LLM API Key (OPTIONAL - 也可通过后台管理页面配置)
# 通过 .env 配置：优先级最高，所有 LLM 调用使用此 Key
# 通过后台管理页面配置：登录后台 > LLM 配置 > API Key 管理 > 添加密钥
#   - Pro Pool: 用于复杂生成任务
#   - Flash Pool: 用于快速轻量任务
# 建议：开发环境用 .env 配置，生产环境通过后台页面动态管理
# LLM_API_KEY=sk-placeholder


# === Celery 任务队列 ===

# Celery Broker (REQUIRED - 如需后台任务 / 异步生成)
# 建议使用独立的 Redis DB
# 当前配置：DB 1 用于 Broker
CELERY_BROKER_URL=redis://localhost:6379/1

# Celery Result Backend (REQUIRED - 如需后台任务 / 异步生成)
# 当前配置：DB 2 用于 Result Backend
CELERY_RESULT_BACKEND=redis://localhost:6379/2


# === CORS 跨域 ===

# 允许的跨域来源 (OPTIONAL, 建议生产环境明确配置为具体域名)
# 多个来源用逗号分隔，生产环境请勿使用通配符
# 生产环境必须配置为实际域名（如 https://your-domain.com），否则前端无法访问 API
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173


# === 限流 ===

# 每个限流周期允许的请求数 (OPTIONAL, default: 1000)
# 开发环境通常设为较高值
# RATE_LIMIT_CALLS=1000

# 限流周期（秒）(OPTIONAL, default: 60)
# RATE_LIMIT_PERIOD=60


# === 归档 ===

# 动态层存档目录 (OPTIONAL, default: ./archives)
# ARCHIVE_DIR=./archives
