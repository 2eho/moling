# =============================================================================
# Moling (墨灵) - 环境变量配置示例
# =============================================================================
# 使用方法：
#   1. 复制本文件为 .env
#   2. 填入真实的值（特别是 REQUIRED 项）
#   3. 切勿将 .env 提交到版本控制
# =============================================================================


# === 运行环境 ===

# 运行环境 (OPTIONAL, default: development)
# 可选值: development | staging | production
# ENVIRONMENT=development


# === 数据库 ===

# PostgreSQL 数据库连接 URL (REQUIRED - 生产环境必须设置)
# 格式: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
# !!! 请将 "moling:moling" 替换为真实的强密码 !!!
DATABASE_URL=postgresql+asyncpg://moling:moling@localhost:5432/moling

# Redis 连接 URL (REQUIRED - 用于缓存和会话)
# 格式: redis://<host>:<port>/<db>
REDIS_URL=redis://localhost:6379/0


# === JWT 认证 ===

# JWT 签名密钥 (REQUIRED - 生产环境必须设置为强密钥，务必修改此值)
# 生成强密钥: openssl rand -hex 32
# !!! 切勿在生产环境使用此默认值 !!!
SECRET_KEY=dev-secret-key-change-in-production

# JWT 签名算法 (OPTIONAL, default: HS256)
# ALGORITHM=HS256

# Access Token 过期时间（分钟）(OPTIONAL, default: 15)
# ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh Token 过期时间（天）(OPTIONAL, default: 7)
# REFRESH_TOKEN_EXPIRE_DAYS=7


# === LLM / AI 服务 ===

# LLM API Base URL (OPTIONAL, default: https://api.deepseek.com)
# 支持 OpenAI 兼容格式的 API
# LLM_API_BASE=https://api.deepseek.com

# LLM API Key (REQUIRED - 如需 LLM 生成功能)
# !!! 请替换为真实的 API Key（如 DeepSeek / OpenAI）!!!
# 此占位值不可用于生产环境
LLM_API_KEY=sk-placeholder


# === Celery 任务队列 ===

# Celery Broker (REQUIRED - 如需后台任务 / 异步生成)
# 建议使用独立的 Redis DB
# 当前配置：DB 1 用于 Broker
CELERY_BROKER_URL=redis://localhost:6379/1

# Celery Result Backend (REQUIRED - 如需后台任务 / 异步生成)
# 当前配置：DB 2 用于 Result Backend
CELERY_RESULT_BACKEND=redis://localhost:6379/2


# === CORS 跨域 ===

# 允许的跨域来源 (OPTIONAL, 建议生产环境明确配置为具体域名)
# 多个来源用逗号分隔，生产环境请勿使用通配符
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173


# === 限流 ===

# 每个限流周期允许的请求数 (OPTIONAL, default: 1000)
# 开发环境通常设为较高值
# RATE_LIMIT_CALLS=1000

# 限流周期（秒）(OPTIONAL, default: 60)
# RATE_LIMIT_PERIOD=60


# === 归档 ===

# 动态层存档目录 (OPTIONAL, default: ./archives)
# ARCHIVE_DIR=./archives
