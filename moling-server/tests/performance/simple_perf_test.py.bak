"""墨灵 (Moling) — 简化性能测试脚本.

使用 requests + concurrent.futures 实现，避免 Locust 在 Windows 上的兼容性问题。

测试目标：
- 认证模块（登录）
- 项目模块（列表、创建、详情）
- 章节模块（列表）
- 卡牌模块（获取卡池）

使用方法：
    python simple_perf_test.py --users 10 --requests 100 --host http://localhost:8000
"""

from __future__ import annotations

import argparse
import concurrent.futures
import json
import logging
import random
import statistics
import time
from dataclasses import dataclass, field
from typing import Dict, List, Optional

import requests
from requests.adapters import HTTPAdapter
from urllib3.util.retry import Retry

# ---------------------------------------------------------------------------
# 配置
# ---------------------------------------------------------------------------

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
)

logger = logging.getLogger(__name__)

#  测试数据
TEST_USERS = [
    {"email": "test1@moling.com", "password": "password123"},
    {"email": "test2@moling.com", "password": "password123"},
    {"email": "test3@moling.com", "password": "password123"},
]

PROJECT_GENRES = ["玄幻", "都市", "武侠", "科幻", "言情", "悬疑"]


# ---------------------------------------------------------------------------
# 数据类
# ---------------------------------------------------------------------------


@dataclass
class RequestResult:
    """单次请求结果."""

    endpoint: str
    method: str
    status_code: int
    response_time: float  # 毫秒
    success: bool
    error: Optional[str] = None


@dataclass
class TestResults:
    """测试结果统计."""

    total_requests: int = 0
    successful_requests: int = 0
    failed_requests: int = 0
    results: List[RequestResult] = field(default_factory=list)

    #  响应时间统计
    min_response_time: float = 0.0
    max_response_time: float = 0.0
    avg_response_time: float = 0.0
    p50_response_time: float = 0.0
    p95_response_time: float = 0.0
    p99_response_time: float = 0.0

    #  按端点分组统计
    endpoint_stats: Dict[str, Dict] = field(default_factory=dict)

    def calculate_stats(self):
        """计算统计信息."""
        if not self.results:
            return

        response_times = [r.response_time for r in self.results]
        self.total_requests = len(self.results)
        self.successful_requests = sum(1 for r in self.results if r.success)
        self.failed_requests = self.total_requests - self.successful_requests

        if response_times:
            self.min_response_time = min(response_times)
            self.max_response_time = max(response_times)
            self.avg_response_time = statistics.mean(response_times)
            self.p50_response_time = statistics.median(response_times)
            sorted_times = sorted(response_times)
            self.p95_response_time = sorted_times[int(len(sorted_times) * 0.95)]
            self.p99_response_time = sorted_times[int(len(sorted_times) * 0.99)]

        #  按端点统计
        endpoint_groups: Dict[str, List[float]] = {}
        for r in self.results:
            key = f"{r.method} {r.endpoint}"
            if key not in endpoint_groups:
                endpoint_groups[key] = []
            endpoint_groups[key].append(r.response_time)

        for endpoint, times in endpoint_groups.items():
            self.endpoint_stats[endpoint] = {
                "count": len(times),
                "min": min(times),
                "max": max(times),
                "avg": statistics.mean(times),
                "p95": sorted(times)[int(len(times) * 0.95)],
            }


# ---------------------------------------------------------------------------
# HTTP 客户端
# ---------------------------------------------------------------------------


def create_session() -> requests.Session:
    """创建带重试机制的 HTTP Session."""
    session = requests.Session()

    #  配置重试
    retry = Retry(
        total=3,
        backoff_factor=0.1,
        status_forcelist=[500, 502, 503, 504],
    )
    adapter = HTTPAdapter(max_retries=retry)
    session.mount("http://", adapter)
    session.mount("https://", adapter)

    return session


def get_auth_headers(token: str) -> Dict[str, str]:
    """构造认证请求头."""
    return {
        "Authorization": f"Bearer {token}",
        "Content-Type": "application/json",
    }


# ---------------------------------------------------------------------------
# 测试任务
# ---------------------------------------------------------------------------


def task_login(session: requests.Session, base_url: str) -> RequestResult:
    """登录任务."""
    start_time = time.time()
    endpoint = "/api/v1/auth/login"
    method = "POST"

    try:
        user = random.choice(TEST_USERS)
        payload = {
            "email": user["email"],
            "password": user["password"],
        }
        response = session.post(f"{base_url}{endpoint}", json=payload, timeout=10)
        elapsed = (time.time() - start_time) * 1000  # 转换为毫秒

        success = response.status_code in (200, 201)
        return RequestResult(
            endpoint=endpoint,
            method=method,
            status_code=response.status_code,
            response_time=elapsed,
            success=success,
        )
    except Exception as e:
        elapsed = (time.time() - start_time) * 1000
        return RequestResult(
            endpoint=endpoint,
            method=method,
            status_code=0,
            response_time=elapsed,
            success=False,
            error=str(e),
        )


def task_list_projects(session: requests.Session, base_url: str, token: str) -> RequestResult:
    """获取项目列表任务."""
    start_time = time.time()
    endpoint = "/api/v1/projects"
    method = "GET"

    try:
        headers = get_auth_headers(token)
        response = session.get(f"{base_url}{endpoint}", headers=headers, timeout=10)
        elapsed = (time.time() - start_time) * 1000

        success = response.status_code in (200, 201)
        return RequestResult(
            endpoint=endpoint,
            method=method,
            status_code=response.status_code,
            response_time=elapsed,
            success=success,
        )
    except Exception as e:
        elapsed = (time.time() - start_time) * 1000
        return RequestResult(
            endpoint=endpoint,
            method=method,
            status_code=0,
            response_time=elapsed,
            success=False,
            error=str(e),
        )


def task_get_project_detail(session: requests.Session, base_url: str, token: str) -> RequestResult:
    """获取项目详情任务."""
    start_time = time.time()
    endpoint = f"/api/v1/projects/{random.randint(1, 50)}"
    method = "GET"

    try:
        headers = get_auth_headers(token)
        response = session.get(f"{base_url}{endpoint}", headers=headers, timeout=10)
        elapsed = (time.time() - start_time) * 1000

        success = response.status_code in (200, 404)  # 404 可能是项目不存在
        return RequestResult(
            endpoint="/api/v1/projects/:id",
            method=method,
            status_code=response.status_code,
            response_time=elapsed,
            success=success,
        )
    except Exception as e:
        elapsed = (time.time() - start_time) * 1000
        return RequestResult(
            endpoint="/api/v1/projects/:id",
            method=method,
            status_code=0,
            response_time=elapsed,
            success=False,
            error=str(e),
        )


def task_create_project(session: requests.Session, base_url: str, token: str) -> RequestResult:
    """创建项目任务."""
    start_time = time.time()
    endpoint = "/api/v1/projects"
    method = "POST"

    try:
        headers = get_auth_headers(token)
        payload = {
            "title": f"性能测试项目{random.randint(1000, 9999)}",
            "author": f"测试作者{random.randint(10, 99)}",
            "genre": random.choice(PROJECT_GENRES),
            "creation_mode": "from_scratch",
            "status": "draft",
        }
        response = session.post(
            f"{base_url}{endpoint}",
            json=payload,
            headers=headers,
            timeout=10,
        )
        elapsed = (time.time() - start_time) * 1000

        success = response.status_code in (200, 201)
        return RequestResult(
            endpoint=endpoint,
            method=method,
            status_code=response.status_code,
            response_time=elapsed,
            success=success,
        )
    except Exception as e:
        elapsed = (time.time() - start_time) * 1000
        return RequestResult(
            endpoint=endpoint,
            method=method,
            status_code=0,
            response_time=elapsed,
            success=False,
            error=str(e),
        )


def task_list_chapters(session: requests.Session, base_url: str, token: str) -> RequestResult:
    """获取章节列表任务."""
    start_time = time.time()
    endpoint = f"/api/v1/chapters?project_id={random.randint(1, 50)}"
    method = "GET"

    try:
        headers = get_auth_headers(token)
        response = session.get(f"{base_url}{endpoint}", headers=headers, timeout=10)
        elapsed = (time.time() - start_time) * 1000

        success = response.status_code in (200, 201)
        return RequestResult(
            endpoint="/api/v1/chapters?project_id",
            method=method,
            status_code=response.status_code,
            response_time=elapsed,
            success=success,
        )
    except Exception as e:
        elapsed = (time.time() - start_time) * 1000
        return RequestResult(
            endpoint="/api/v1/chapters?project_id",
            method=method,
            status_code=0,
            response_time=elapsed,
            success=False,
            error=str(e),
        )


def task_get_card_pool(session: requests.Session, base_url: str, token: str) -> RequestResult:
    """获取卡池任务."""
    start_time = time.time()
    endpoint = f"/api/v1/projects/{random.randint(1, 50)}/cards/pool?count=3"
    method = "GET"

    try:
        headers = get_auth_headers(token)
        response = session.get(f"{base_url}{endpoint}", headers=headers, timeout=10)
        elapsed = (time.time() - start_time) * 1000

        success = response.status_code in (200, 201)
        return RequestResult(
            endpoint="/api/v1/projects/:id/cards/pool",
            method=method,
            status_code=response.status_code,
            response_time=elapsed,
            success=success,
        )
    except Exception as e:
        elapsed = (time.time() - start_time) * 1000
        return RequestResult(
            endpoint="/api/v1/projects/:id/cards/pool",
            method=method,
            status_code=0,
            response_time=elapsed,
            success=False,
            error=str(e),
        )


# ---------------------------------------------------------------------------
# 工作线程
# ---------------------------------------------------------------------------


def worker_task(
    base_url: str,
    token: str,
    num_requests: int,
    worker_id: int,
) -> List[RequestResult]:
    """单个工作线程的任务."""
    session = create_session()
    results = []

    logger.debug(f"Worker {worker_id} started, will send {num_requests} requests")

    for i in range(num_requests):
        #  随机选择一个任务（按权重）
        task_weights = [
            (task_login, 5),
            (task_list_projects, 10),
            (task_get_project_detail, 8),
            (task_create_project, 3),
            (task_list_chapters, 6),
            (task_get_card_pool, 4),
        ]

        #  根据权重选择任务
        total_weight = sum(w for _, w in task_weights)
        r = random.uniform(0, total_weight)
        cumulative = 0
        selected_task = task_list_projects  #  默认任务
        for task, weight in task_weights:
            cumulative += weight
            if r <= cumulative:
                selected_task = task
                break

        #  执行任务
        if selected_task == task_login:
            result = task_login(session, base_url)
        elif selected_task == task_list_projects:
            result = task_list_projects(session, base_url, token)
        elif selected_task == task_get_project_detail:
            result = task_get_project_detail(session, base_url, token)
        elif selected_task == task_create_project:
            result = task_create_project(session, base_url, token)
        elif selected_task == task_list_chapters:
            result = task_list_chapters(session, base_url, token)
        elif selected_task == task_get_card_pool:
            result = task_get_card_pool(session, base_url, token)
        else:
            continue

        results.append(result)

        #  打印进度（每 10 个请求）
        if (i + 1) % 10 == 0:
            logger.debug(f"Worker {worker_id}: {i + 1}/{num_requests} requests completed")

    return results


# ---------------------------------------------------------------------------
# 主测试流程
# ---------------------------------------------------------------------------


def run_performance_test(
    base_url: str,
    num_users: int,
    num_requests: int,
    token: str,
) -> TestResults:
    """运行性能测试."""
    logger.info("=" * 60)
    logger.info("墨灵性能测试开始")
    logger.info(f"目标主机: {base_url}")
    logger.info(f"并发用户数: {num_users}")
    logger.info(f"每用户请求数: {num_requests}")
    logger.info(f"总请求数: {num_users * num_requests}")
    logger.info("=" * 60)

    all_results = []
    start_time = time.time()

    #  使用线程池执行测试
    with concurrent.futures.ThreadPoolExecutor(max_workers=num_users) as executor:
        futures = []
        for i in range(num_users):
            future = executor.submit(
                worker_task,
                base_url,
                token,
                num_requests,
                i + 1,
            )
            futures.append(future)

        #  收集结果
        for future in concurrent.futures.as_completed(futures):
            worker_results = future.result()
            all_results.extend(worker_results)

    total_time = time.time() - start_time

    #  统计结果
    test_results = TestResults(results=all_results)
    test_results.calculate_stats()

    #  添加吞吐量信息
    test_results.total_time = total_time
    test_results.throughput = test_results.total_requests / total_time if total_time > 0 else 0

    return test_results


def print_results(results: TestResults):
    """打印测试结果."""
    print("\n" + "=" * 60)
    print("性能测试结果")
    print("=" * 60)

    print(f"\n总请求数: {results.total_requests}")
    print(f"成功请求数: {results.successful_requests}")
    print(f"失败请求数: {results.failed_requests}")
    print(f"成功率: {results.successful_requests / results.total_requests * 100:.2f}%")
    print(f"总测试时间: {results.total_time:.2f}s")
    print(f"吞吐量: {results.throughput:.2f} 请求/秒")

    print("\n--- 响应时间统计 (ms) ---")
    print(f"最小响应时间: {results.min_response_time:.2f} ms")
    print(f"最大响应时间: {results.max_response_time:.2f} ms")
    print(f"平均响应时间: {results.avg_response_time:.2f} ms")
    print(f"P50 响应时间: {results.p50_response_time:.2f} ms")
    print(f"P95 响应时间: {results.p95_response_time:.2f} ms")
    print(f"P99 响应时间: {results.p99_response_time:.2f} ms")

    print("\n--- 按端点统计 ---")
    for endpoint, stats in results.endpoint_stats.items():
        print(f"\n{endpoint}:")
        print(f"  请求数: {stats['count']}")
        print(f"  最小: {stats['min']:.2f} ms")
        print(f"  最大: {stats['max']:.2f} ms")
        print(f"  平均: {stats['avg']:.2f} ms")
        print(f"  P95: {stats['p95']:.2f} ms")

    print("\n" + "=" * 60)

    #  判断是否达标
    print("\n--- 性能评估 ---")
    if results.p95_response_time < 500:
        print("✅ P95 响应时间 < 500ms (达标)")
    else:
        print("❌ P95 响应时间 >= 500ms (不达标)")

    if results.throughput > 10:
        print("✅ 吞吐量 > 10 请求/秒 (达标)")
    else:
        print("⚠️  吞吐量 <= 10 请求/秒 (需优化)")

    print("=" * 60)


def save_results_json(results: TestResults, filename: str):
    """保存结果到 JSON 文件."""
    data = {
        "summary": {
            "total_requests": results.total_requests,
            "successful_requests": results.successful_requests,
            "failed_requests": results.failed_requests,
            "success_rate": results.successful_requests / results.total_requests * 100 if results.total_requests > 0 else 0,
            "total_time": results.total_time,
            "throughput": results.throughput,
        },
        "response_time": {
            "min": results.min_response_time,
            "max": results.max_response_time,
            "avg": results.avg_response_time,
            "p50": results.p50_response_time,
            "p95": results.p95_response_time,
            "p99": results.p99_response_time,
        },
        "endpoint_stats": results.endpoint_stats,
    }

    with open(filename, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)

    logger.info(f"结果已保存到: {filename}")


# ---------------------------------------------------------------------------
# 主入口
# ---------------------------------------------------------------------------


def main():
    """主函数."""
    parser = argparse.ArgumentParser(description="墨灵性能测试工具")
    parser.add_argument(
        "--host",
        default="http://localhost:8000",
        help="后端服务地址 (default: http://localhost:8000)",
    )
    parser.add_argument("--users", type=int, default=10, help="并发用户数 (default: 10)")
    parser.add_argument(
        "--requests",
        type=int,
        default=100,
        help="每用户请求数 (default: 100)",
    )
    parser.add_argument(
        "--token",
        default="test",
        help="认证 Token (default: test)",
    )
    parser.add_argument(
        "--output",
        default="performance_report.json",
        help="输出文件名 (default: performance_report.json)",
    )

    args = parser.parse_args()

    #  运行测试
    results = run_performance_test(
        base_url=args.host,
        num_users=args.users,
        num_requests=args.requests,
        token=args.token,
    )

    #  打印结果
    print_results(results)

    #  保存结果
    save_results_json(results, args.output)


if __name__ == "__main__":
    main()
