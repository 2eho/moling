# Database
DATABASE_URL=sqlite:./moling.db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=

# Auth
SECRET_KEY=change-me-to-a-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM
LLM_API_BASE=https://api.deepseek.com
LLM_API_KEY=sk-your-api-key
# LLM_PRO_KEYS=sk-pro-key-1,sk-pro-key-2
# LLM_FLASH_KEYS=sk-flash-key-1,sk-flash-key-2
LLM_DEFAULT_MODEL=deepseek-chat
LLM_LARGE_MODEL=deepseek-chat
LLM_MEDIUM_MODEL=deepseek-chat
LLM_SMALL_MODEL=deepseek-chat
KEY_SELECT_STRATEGY=least_usage

# Budget
TOKEN_BUDGET_LIMIT=1000000

# Celery / Worker Bridge
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS
CORS_ORIGINS=*

# Rate Limiting
RATE_LIMIT_CALLS=100
RATE_LIMIT_PERIOD=60

# Monitoring
# SENTRY_DSN=
LOG_LEVEL=INFO
AUDIT_LOG_DIR=./logs

# Server
HOST=0.0.0.0
PORT=8000
BASE_PATH=/api/v1

# Content Length
MAX_BODY_SIZE=10485760

# Phase 4
PHASE4_AUTO_MODE=true
PHASE4_REVIEW_TIMEOUT_HOURS=72

# Email (placeholder for future)
# SMTP_HOST=
# SMTP_PORT=
