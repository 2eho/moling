# ==============================================================================
# 墨灵 Moling — Rust 后端环境变量模板
# ==============================================================================
# 复制为 .env 并填写实际值
#   cp .env.example .env
#
# 变量命名规则: 所有变量支持 MOLING_ 前缀和裸名两种形式
#   MOLING_DATABASE_URL 和 DATABASE_URL 等价（推荐使用 MOLING_ 前缀）
# ==============================================================================

# ── 数据库 ───────────────────────────────────────────────────
MOLING_DATABASE_URL=sqlite:../moling.db
MOLING_DATABASE_POOL_SIZE=20
MOLING_DATABASE_MAX_OVERFLOW=10

# ── Redis ────────────────────────────────────────────────────
MOLING_REDIS_URL=redis://localhost:6379/0
# MOLING_REDIS_PASSWORD=

# ── Auth / JWT ───────────────────────────────────────────────
MOLING_SECRET_KEY=change-me-to-a-random-secret
MOLING_ALGORITHM=HS256
MOLING_ACCESS_TOKEN_EXPIRE_MINUTES=60
MOLING_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM (DeepSeek) ──────────────────────────────────────────
MOLING_LLM_API_BASE=https://api.deepseek.com
MOLING_LLM_API_KEY=sk-your-api-key
# MOLING_LLM_PRO_KEYS=sk-pro-key-1,sk-pro-key-2
# MOLING_LLM_FLASH_KEYS=sk-flash-key-1,sk-flash-key-2
MOLING_LLM_DEFAULT_MODEL=deepseek-chat
MOLING_LLM_LARGE_MODEL=deepseek-chat
MOLING_LLM_MEDIUM_MODEL=deepseek-chat
MOLING_LLM_SMALL_MODEL=deepseek-chat
MOLING_KEY_SELECT_STRATEGY=least_usage

# ── Token Budget ─────────────────────────────────────────────
MOLING_TOKEN_BUDGET_LIMIT=1000000

# ── CORS ─────────────────────────────────────────────────────
MOLING_CORS_ORIGINS=*

# ── Rate Limiting ────────────────────────────────────────────
MOLING_RATE_LIMIT_CALLS=100
MOLING_RATE_LIMIT_PERIOD=60

# ── Monitoring ───────────────────────────────────────────────
# MOLING_SENTRY_DSN=
MOLING_LOG_LEVEL=INFO
MOLING_AUDIT_LOG_DIR=./logs

# ── Server ───────────────────────────────────────────────────
MOLING_HOST=0.0.0.0
MOLING_PORT=8000
MOLING_BASE_PATH=/api/v1

# ── Content Length ───────────────────────────────────────────
MOLING_MAX_BODY_SIZE=10485760

# ── Phase 4 ──────────────────────────────────────────────────
MOLING_PHASE4_AUTO_MODE=true
MOLING_PHASE4_REVIEW_TIMEOUT_HOURS=72

# ── Email (预留) ─────────────────────────────────────────────
# MOLING_SMTP_HOST=
# MOLING_SMTP_PORT=
